rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isValidStats(data) {
      return data.reelsCount is int
          && data.shortsCount is int
          && data.reelsCount >= 0
          && data.shortsCount >= 0
          && data.reelsCount <= 10000   // anti-cheat cap
          && data.shortsCount <= 10000;
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
          // Prevent manual editing of instagramUsername
          && (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['instagramUsername'])
              || request.resource.data.instagramUsername == resource.data.instagramUsername);
      allow delete: if false;
    }

    // ── Daily Stats ───────────────────────────────────────────────────────
    match /daily_stats/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
          && isOwner(resource == null
              ? request.resource.data.uid
              : resource.data.uid)
          && isValidStats(request.resource.data);
    }

    // ── Friends ───────────────────────────────────────────────────────────
    match /friends/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn()
          && (resource.data.uid == request.auth.uid
              || resource.data.friendUid == request.auth.uid);
      allow update: if false;
    }

    // ── Friend Requests ───────────────────────────────────────────────────
    match /requests/{docId} {
      allow read: if isSignedIn()
          && (resource.data.fromUid == request.auth.uid
              || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn()
          && request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn()
          && resource.data.toUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status']);
      allow delete: if false;
    }

    // ── Leaderboard ───────────────────────────────────────────────────────
    match /leaderboard/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // written by Cloud Functions only
    }

    // ── Achievements ──────────────────────────────────────────────────────
    match /achievements/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // written by Cloud Functions only
    }
  }
}
